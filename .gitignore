# Virtual environment
.venv/

# Python cache
__pycache__/
*.pyc

# Logs and outputs
logs/
output/
downloaded_files/

# Screenshots — ignore everything except .gitkeep so the folder is tracked
screenshots/*
!screenshots/.gitkeep

# Local config / secrets
config/*.json
!config/*.json.example
.env

# Build artifacts
*.egg-info/
dist/
build/

# Working artifacts
tasks/
.claude/
CLAUDE.md
*.db

# Data files
*.xlsx
*.xls
*.xlsm
*.csv

# OS junk
.DS_Store
