# --- Chrome ---------------------------------------------------------------
# Full path to the Chrome User Data directory used for automation. Use a
# dedicated automation profile (NOT your personal Chrome dir) so the script
# never fights your day-to-day browsing for the same profile lock.
CHROME_USER_DATA_DIR=C:/ChromeAutomationProfile

# --- Credentials ----------------------------------------------------------
# Amazon Seller Central sign-in.
AMZN_email=your_amazon_email@example.com
AMZN_pass=your_amazon_password

# --- Alerting -------------------------------------------------------------
# Outlook account used by seller_automation_utils.alert_utils.handle_crash to
# email a screenshot + traceback if a run fails.
ALERT_EMAIL=alerts@example.com

# --- Email report ---------------------------------------------------------
# Outlook account the summary email is sent from.
SENDER_EMAIL=sender@example.com
# Recipient(s) of the summary email (comma-separated for multiple).
TO_EMAIL=recipient@example.com
# Optional CC recipient(s), comma-separated. Leave blank for none.
CC_EMAIL=cc@example.com
